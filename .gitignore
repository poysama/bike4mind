.claude/settings.local.json
.claude/worktrees
.claude/scheduled_tasks.lock

b4m-core/**/*sst-env.d.ts
packages/premium/**/sst-env.d.ts
b4m-core/**/*dist
# OptiHashi engine + container build to dist/ inside the OptiHashi overlay (M-engine).
packages/premium/**/dist

# Old b4m-core submodule artifacts (no longer needed)
b4m-core/.envrc
b4m-core/.github/
b4m-core/.rebuild
b4m-core/flake.lock
b4m-core/flake.nix
# Ignore generated code maps (but not docs-site/docs/agents/)
/agents/
!docs-site/docs/agents/

# Debug log files
message-count-debug.log

# Bike4Mind local config (developer-specific)
.bike4mind/local.json

# Capacitor native builds
apps/client/ios/
apps/client/android/
packages/client/

# IDE
.idea/
.cursor/commands/
.vscode/keybindings.json

# B4M checkpoint data
.b4m/

.playwright-cli/
.playwright-mcp/

# Playwright screenshots written to the repo root (MCP screenshot calls with a
# relative filename land here rather than in .playwright-mcp/). These are local
# verification artifacts, not source.
page-*.png
page-*.jpeg
*-verify-*.png
# E2E test screenshots saved at root with descriptive names (e.g. `e2e-skills-picker.png`).
e2e-*.png
e2e-*.jpeg
# PR-scoped verification screenshots (e.g. `pr9757-pdf-rendered.png`) — local captures from
# manual PR verification, named after the PR number. Not source.
pr[0-9]*-*.png
pr[0-9]*-*.jpeg

# Tavern (CraftPix) assets — NOT tracked here. Their source of truth is the
# b4m-tavern premium overlay; apps/client/scripts/copy-tavern-assets.mjs hydrates
# this dir from packages/premium/tavern at postinstall (no-op for open-core forks
# without the overlay). The CraftPix Limited License forbids redistributing source
# files, so the public open-core snapshot must not ship them (NOTICE §1).
apps/client/public/assets/tavern/
craftpix-zips/

# Local open-core scratch/deliverables — never commit (a tracked scratchpad file
# would ship in the git-archive snapshot; see opencore-secret-scan.sh PRUNE_RE note).
/scratchpad/
