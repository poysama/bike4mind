{
  "name": "@bike4mind/fab-pipeline",
  "version": "0.5.0",
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Bike4Mind/bike4mind.git",
    "directory": "b4m-core/fab-pipeline"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsdown",
    "incremental": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit --types node",
    "typecheck:fast": "tsgo --noEmit --types node || tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1069.0",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/credential-provider-node": "^3.972.56",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@bike4mind/common": "workspace:*",
    "@bike4mind/observability": "workspace:*",
    "@opensearch-project/opensearch": "2.11.0",
    "@smithy/node-http-handler": "^4.8.0",
    "axios": "1.16.1",
    "cheerio": "1.2.0",
    "file-type": "^22.0.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.2",
    "openai": "^6.38.0",
    "tiktoken": "^1.0.22",
    "unpdf": "^1.6.2",
    "voyageai": "^0.4.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
